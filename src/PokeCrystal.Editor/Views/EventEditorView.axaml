<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PokeCrystal.Editor.ViewModels"
             x:Class="PokeCrystal.Editor.Views.EventEditorView"
             x:DataType="vm:EventEditorViewModel">

    <Grid ColumnDefinitions="220,*">

        <!-- Left: map list + NPC list -->
        <DockPanel Grid.Column="0" Margin="4">

            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                <TextBlock Text="Maps" FontWeight="Bold" />
                <Button Content="Load Selected"
                        Command="{Binding LoadMapCommand}"
                        CommandParameter="{Binding SelectedMapId}" />
            </StackPanel>

            <ListBox ItemsSource="{Binding AvailableMapIds}"
                     SelectedItem="{Binding SelectedMapId}" />

        </DockPanel>

        <!-- Right: NPC list + properties -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="4">

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="NPCs" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Content="Add NPC" Command="{Binding AddNpcCommand}" />
                <Button Content="Remove Selected"
                        Command="{Binding RemoveNpcCommand}"
                        CommandParameter="{Binding SelectedNpc}" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Npcs}"
                     SelectedItem="{Binding SelectedNpc}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding SpriteId}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Selected NPC properties -->
            <StackPanel Grid.Row="2" Margin="0,8,0,0" Spacing="4"
                        IsVisible="{Binding SelectedNpc, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="Selected NPC" FontWeight="Bold" />
                <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto" >
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Sprite ID" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedNpc.SpriteId}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="X" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNpc.X}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Y" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNpc.Y}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Script" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedNpc.ScriptId}" />
                </Grid>
            </StackPanel>

        </Grid>

    </Grid>
</UserControl>
