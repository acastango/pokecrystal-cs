<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PokeCrystal.Editor.ViewModels"
             x:Class="PokeCrystal.Editor.Views.TilesetEditorView"
             x:DataType="vm:TilesetEditorViewModel">

    <Grid ColumnDefinitions="220,*">

        <!-- Left: tileset list -->
        <DockPanel Grid.Column="0" Margin="4">
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                <TextBlock Text="Tilesets" FontWeight="Bold" />
                <Button Content="Import PNG…" Command="{Binding ImportPngCommand}" />
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </StackPanel>
            <ListBox ItemsSource="{Binding AvailableTilesets}"
                     SelectedItem="{Binding SelectedTileset}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Id}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Right: selected tileset properties -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="8" Spacing="8"
                        IsVisible="{Binding SelectedTileset, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="Tileset Properties" FontWeight="Bold" />
                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTileset.Id}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="File" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTileset.File}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Color Mode" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedTileset.ColorMode}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Bits/Pixel" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedTileset.BitsPerPixel}" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Cell Size" />
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="{Binding SelectedTileset.CellWidth, StringFormat={}{0}}" />
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Has Alpha" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedTileset.HasAlpha}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
